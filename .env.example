# ===================================================================
# DDoS Shield — Environment Variables
# ===================================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# ===================================================================

# --- Simulation Mode ---
# Set to "true" for demo/classroom use (no real packet capture needed)
SIMULATION_MODE=true
SIM_DEVICE_COUNT=8
SIM_ATTACK_PROB=0.15
SIM_TICK_INTERVAL=2.0

# --- Packet Sniffer (real mode only) ---
SNIFFER_INTERFACE=
SNIFFER_BPF_FILTER=
SNIFFER_WINDOW_SECONDS=10
SNIFFER_MAX_BUFFER=100000

# --- Detection Thresholds (packets per second) ---
THRESH_SYN_PPS=100
THRESH_UDP_PPS=500
THRESH_ICMP_PPS=200
THRESH_HTTP_PPS=150
THRESH_ARP_PPS=50
ZSCORE_THRESHOLD=3.0
ZSCORE_MIN_SAMPLES=30

# --- Mitigation ---
AUTO_BLOCK=false
RATE_LIMIT_PPS=50
BLOCK_DURATION=300

# --- Authentication ---
JWT_SECRET=change-me-in-production
TOKEN_EXPIRE_MINUTES=60
DEFAULT_USER=admin
DEFAULT_PASS=ddos-shield-2024

# --- Database ---
DATABASE_URL=sqlite:///./ddos_shield.db

# --- WebSocket ---
WS_INTERVAL=1.0
